MASTER_PANEL_URL='http://master.example.com:8080'
MASTER_REGISTER_TOKEN='change-this-register-token'

AGENT_NAME='edge-01'
AGENT_TOKEN='change-this-agent-token'
AGENT_PUBLIC_URL=''
AGENT_VERSION='1'
AGENT_TAGS='edge,emby'
AGENT_CAPABILITIES='http_rules,local_acme,cert_install,l4'
AGENT_HEARTBEAT_INTERVAL_MS='10000'

AGENT_HOME='/opt/nginx-reverse-emby-agent'
AGENT_RUNTIME_DIR='/opt/nginx-reverse-emby-agent/runtime'
RULES_JSON='/opt/nginx-reverse-emby-agent/proxy_rules.json'
L4_RULES_JSON='/opt/nginx-reverse-emby-agent/l4_rules.json'
MANAGED_CERTS_JSON='/opt/nginx-reverse-emby-agent/managed_certificates.json'
MANAGED_CERTS_POLICY_JSON='/opt/nginx-reverse-emby-agent/managed_certificates.policy.json'
AGENT_STATE_FILE='/opt/nginx-reverse-emby-agent/agent-state.json'

# Built-in apply script installed by join-agent.sh
APPLY_COMMAND='/opt/nginx-reverse-emby-agent/bin/nginx-reverse-emby-apply.sh'

# Remote agents usually use direct; set AGENT_FOLLOW_MASTER_DEPLOY_MODE=1 to follow master mode
PROXY_DEPLOY_MODE='direct'
# AGENT_FOLLOW_MASTER_DEPLOY_MODE='1'

NGINX_BIN='nginx'
NGINX_STATUS_URL='http://127.0.0.1:18080/nginx_status'
DIRECT_CERT_DIR='/opt/nginx-reverse-emby-agent/certs'
ACME_HOME='/opt/nginx-reverse-emby-agent/.acme.sh'
